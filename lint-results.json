en: process.env.SANITY_API_TOKEN,\n  useCdn: false,\n});\nasync function run() {\n  const post = await client.fetch(`*[_type == \"post\" && slug.current == \"learning-ai-world\"][0] { _id, body }`);\n  if (!post || !post.body) return console.log('Post not found');\n  const body = post.body;\n  const firstBlock = body[0];\n  if (firstBlock.children && firstBlock.children[0].text.includes(\"どうも、てっしゅうです\")) {\n    if (!firstBlock.children[0].text.includes(\"[st-kaiwa1 r]\")) {\n      firstBlock.children[0].text = \"[st-kaiwa1 r]\" + firstBlock.children[0].text;\n      const lastSpan = firstBlock.children[firstBlock.children.length - 1];\n      lastSpan.text = lastSpan.text + \"[/st-kaiwa1]\";\n      await client.patch(post._id).set({ body: body }).commit();\n      console.log('Successfully patched the document with st-kaiwa tags!');\n    } else {\n      console.log('Already has tags.');\n    }\n  } else {\n    console.log('First block is not the expected text: ', firstBlock.children[0].text);\n  }\n}\nrun().catch(console.error);\n","usedDeprecatedRules":[]},{"filePath":"/Users/apple/Documents/Vibecoding/tesshumatsuo/postcss.config.mjs","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/apple/Documents/Vibecoding/tesshumatsuo/sanity.cli.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/apple/Documents/Vibecoding/tesshumatsuo/sanity.config.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/apple/Documents/Vibecoding/tesshumatsuo/scripts/wp-import.ts","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","l